<Window x:Class="NekoBot.WPFProgram.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="NekoBot" 
        Height="450" 
        Width="800" 
        MinHeight="400" 
        MinWidth="700"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        Background="#FF1D1D1D"
        Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>

        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ScrollContentPresenter Grid.Row="0" Grid.Column="0" 
                                                Margin="{TemplateBinding Padding}"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" 
                                   Grid.Row="0" Grid.Column="1"
                                   Orientation="Vertical"
                                   Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                   ViewportSize="{Binding ViewportHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                   Minimum="0" Maximum="{Binding ScrollableHeight, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Width="6" 
                                   Margin="2,0">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid>
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.Thumb>
                                                    <Thumb MinHeight="40" Width="5">
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="#5A5A5A" CornerRadius="3" />
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                        <Thumb.Style>
                                                            <Style TargetType="Thumb">
                                                                <Setter Property="Background" Value="#5A5A5A"/>
                                                                <Style.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#888888"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Thumb.Style>
                                                    </Thumb>
                                                </Track.Thumb>
                                                <Track.DecreaseRepeatButton>
                                                    <RepeatButton Width="0" Height="0" />
                                                </Track.DecreaseRepeatButton>
                                                <Track.IncreaseRepeatButton>
                                                    <RepeatButton Width="0" Height="0" />
                                                </Track.IncreaseRepeatButton>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EnabledBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FF585858"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFAFAFAF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisabledBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Gray"/>
            <Setter Property="Cursor" Value="No"/>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#FF121212">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="/nekoqq.ico" Width="25" Height="25" Margin="10,8,64,8"/>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="40,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Neko Bot" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
            </StackPanel>

            <TextBlock Grid.Column="1" Text="机器人 AppId: $APPID" FontSize="13" Name="AppIdTextBar" 
               HorizontalAlignment="Center" VerticalAlignment="Center" 
               Foreground="White" Opacity="0.7"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,12,0">
                <Button x:Name="MinimizeButton" 
                Width="30" Height="30" 
                Cursor="Hand"
                Margin="4,0"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MinimizeWindow"
                Background="Transparent"
                BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock Text="─" FontSize="16" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#0078D4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="CloseButton" 
                Width="30" Height="30" 
                Cursor="Hand"
                Margin="4,0"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="CloseWindow"
                Background="Transparent"
                BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock Text="✕" FontSize="14" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF8C00"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="20,16,20,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Background="#FF1F1F1F" CornerRadius="12" Padding="16" 
                        BorderBrush="#FF171717" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="机器人状态" FontSize="12" Foreground="White" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Ellipse Width="10" Height="10" Fill="#4CAF50" Margin="0,4,8,0" Name="BotStatusColor"/>
                            <TextBlock Text="运行中" FontSize="16" FontWeight="Bold" Foreground="#FF216D00" Name="BotStatusText"/>
                        </StackPanel>
                        <Separator Background="#FF171717" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="机器人昵称：" FontSize="12" Foreground="White" Width="80"/>
                            <TextBlock Text="未知" FontSize="12" Foreground="White" Name="BotNicknameText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="指令总数：" FontSize="12" Foreground="White" Width="80"/>
                            <TextBlock Text="0" FontSize="12" Foreground="White" Name="BotCommandsText"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="插件总数：" FontSize="12" Foreground="White" Width="80"/>
                            <TextBlock Text="0" FontSize="12" Foreground="White" Name="BotPluginsText"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#FF1F1F1F" CornerRadius="12" Padding="16" 
                        BorderBrush="#FF171717" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="实时统计" FontSize="12" Foreground="#8A99B4" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📁 消息总数" FontSize="12" Foreground="#A0AABF"/>
                                <TextBlock Text="0" FontSize="20" FontWeight="Bold" Foreground="#4CAF50" Name="MessageCountText"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="💬 聊天总数" FontSize="12" Foreground="#A0AABF"/>
                                <TextBlock Text="0" FontSize="20" FontWeight="Bold" Foreground="#42A5F5" Name="ChatCountText"/>
                            </StackPanel>

                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"/>
                            <StackPanel Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Background="#FF1F1F1F" CornerRadius="12" Padding="16" 
                        BorderBrush="#FF171717" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="快捷操作" FontSize="12" Foreground="#8A99B4" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="StartServiceBorder"
                                CornerRadius="8" Padding="8,6"
                                MouseLeftButtonDown="StartService"
                                Style="{StaticResource DisabledBorderStyle}">
                                <TextBlock Text="启动机器人" HorizontalAlignment="Center" FontSize="12" Foreground="#E0E0E0"/>
                            </Border>

                            <Border x:Name="StopServiceBorder"
                                Grid.Row="0" Grid.Column="1"
                                CornerRadius="8" Padding="8,6"
                                MouseLeftButtonDown="StopService"
                                Style="{StaticResource DisabledBorderStyle}">
                                <TextBlock Text="关闭机器人" HorizontalAlignment="Center" FontSize="12" Foreground="#E0E0E0"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="#FF1D1D1D" CornerRadius="12" 
                    BorderBrush="#FF121212" BorderThickness="1" Margin="16,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF151515" CornerRadius="12,12,0,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 日志" FontWeight="SemiBold" FontSize="13" Foreground="#FFF7F7F7"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer x:Name="LogScrollViewer" 
                          Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto" 
                          Margin="0,4,0,4" 
                          Style="{StaticResource ModernScrollViewer}">
                        <ItemsControl x:Name="LogItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="local:LogEntry">
                                    <Border BorderBrush="#FF2A2A2A" BorderThickness="0" Padding="12,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Time}" 
                               FontSize="12" Foreground="#888888" Width="115"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Message}" 
                               FontSize="12" Foreground="{Binding MessageColor}" 
                               TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FF151515" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Name="TcpStatus" Grid.Column="0" Text=" Tcp WebSocket 已连接" FontSize="11" Foreground="#FFE8E8E8" Margin="15,8,478,8" Grid.ColumnSpan="2"/>
                <Ellipse Name="TcpStatusColor" Width="10" Height="10" Fill="#4CAF50" Margin="5,10,87,10"/>

                <TextBlock Grid.Column="2" Text="Powered by CNCSharp-DevTeam" FontSize="10" Foreground="#5A6A82" Margin="0,8,0,8"/>
            </Grid>
        </Border>
    </Grid>
</Window>